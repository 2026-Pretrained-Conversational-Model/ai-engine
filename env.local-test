# .env.local-test
# 로컬에서 dummy_sagemaker 서버로 FastAPI 파이프라인 테스트할 때 쓰는 환경변수.
#
# 사용법:
#   터미널 1) python -m tools.dummy_sagemaker          ← 더미 서버 (포트 9000)
#   터미널 2) cp .env.local-test .env && uvicorn app.main:app --port 8000   ← 오케스트레이터
#   터미널 3) curl -X POST http://localhost:8000/chat \
#             -H "Content-Type: application/json" \
#             -d '{"session_id":"test-1","user_text":"안녕하세요"}'

LLM_BACKEND=sagemaker

# 이 줄이 핵심: boto3 대신 localhost:9000으로 HTTP 호출
SAGEMAKER_BASE_URL=http://localhost:9000

# endpoint 이름은 HTTP 모드에서는 안 쓰이지만 기본값 유지
SAGEMAKER_ANSWER_ENDPOINT=qwen25-7b-answer-async
SAGEMAKER_ROUTER_ENDPOINT=qwen25-3b-router-async
SAGEMAKER_SUMMARY_ENDPOINT=qwen25-3b-summary-async

# 임베딩 (CPU로 로컬에서 로드)
EMBEDDING_MODEL_NAME=jhgan/ko-sroberta-multitask
EMBEDDING_DIM=768
EMBEDDING_DEVICE=cpu

# 파일 저장 경로
LOCAL_FILE_DIR=/tmp/ai-orchestrator

# 세션 캡
SESSION_MAX_BYTES=20971520

# memory update 정책
MEMORY_UPDATE_EVERY_N_TURNS=3
MEMORY_UPDATE_WINDOW_TURNS=3
ANSWER_MAX_NEW_TOKENS=800
