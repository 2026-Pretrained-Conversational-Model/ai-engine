# ===== App =====
APP_NAME=ai-orchestrator
APP_HOST=0.0.0.0
APP_PORT=8000
LOG_LEVEL=INFO

# ===== Session / Memory =====
# Per-session hard cap (bytes). When exceeded → session is purged.
SESSION_MAX_BYTES=10485760          # 10 MB
SESSION_IDLE_TIMEOUT_MIN=30
RECENT_MESSAGES_WINDOW=6

# ===== File storage =====
LOCAL_FILE_DIR=/tmp/ai-orchestrator
DELETE_FILE_ON_EXPIRE=true

# ===== SageMaker endpoints =====
AWS_REGION=ap-northeast-2
SAGEMAKER_LLM_ENDPOINT=llm-endpoint-name
SAGEMAKER_VLM_ENDPOINT=vlm-endpoint-name
SAGEMAKER_TIMEOUT_SEC=60

# ===== Embedding =====
EMBEDDING_MODEL_NAME=BAAI/bge-m3
EMBEDDING_DEVICE=cpu                # or cuda
EMBEDDING_DIM=1024

# ===== PDF / RAG =====
PDF_CHUNK_SIZE=800
PDF_CHUNK_OVERLAP=100
RAG_TOP_K=4
