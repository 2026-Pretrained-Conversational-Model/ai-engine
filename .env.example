# =========================================================================
# AI Orchestrator (FastAPI) — 환경 변수 예시
# app/core/config.py 의 Settings 와 1:1로 일치합니다.
# =========================================================================

# ===== App =====
APP_NAME=ai-orchestrator
APP_HOST=0.0.0.0
APP_PORT=8000
LOG_LEVEL=INFO

# ===== Session / Memory =====
# 세션 1개의 하드 캡(bytes). 초과 시 세션을 파기하고 expired=true 반환.
SESSION_MAX_BYTES=10485760            # 10 MB
SESSION_IDLE_TIMEOUT_MIN=30
RECENT_MESSAGES_WINDOW=6              # 프롬프트에 넣는 최근 메시지 수

# ===== File storage =====
LOCAL_FILE_DIR=/tmp/ai-orchestrator
DELETE_FILE_ON_EXPIRE=true

# ===== LLM backend =====
# local    : Colab/RunPod에서 직접 로딩한 모델(LocalModelRegistry) 사용
# sagemaker: 원격 SageMaker 엔드포인트 호출
LLM_BACKEND=local

# ===== SageMaker endpoints (LLM_BACKEND=sagemaker 일 때) =====
AWS_REGION=ap-northeast-2
SAGEMAKER_ANSWER_ENDPOINT=ai-orchestrator-answer-v1
SAGEMAKER_ROUTER_ENDPOINT=ai-orchestrator-router-v1
SAGEMAKER_SUMMARY_ENDPOINT=ai-orchestrator-memory-v1
SAGEMAKER_VLM_ENDPOINT=qwen25-vlm-async
SAGEMAKER_TIMEOUT_SEC=120
# 로컬 테스트용: 값이 있으면 boto3 대신 이 URL로 HTTP POST (tools/dummy_sagemaker.py)
SAGEMAKER_BASE_URL=

# ===== Embedding =====
EMBEDDING_MODEL_NAME=jhgan/ko-sroberta-multitask
EMBEDDING_DEVICE=cpu                  # or cuda
EMBEDDING_DIM=768

# ===== PDF / RAG =====
PDF_CHUNK_SIZE=800
PDF_CHUNK_OVERLAP=100
RAG_TOP_K=4

# ===== Memory update policy =====
MEMORY_UPDATE_EVERY_N_TURNS=3         # user 발화 N턴마다 메모리 갱신
MEMORY_UPDATE_WINDOW_TURNS=3          # 갱신 시 입력으로 넣는 직전 턴 수

# ===== Answer generation =====
ANSWER_MAX_NEW_TOKENS=800             # 답변 생성 토큰 상한(지연·언어전환 방어)
